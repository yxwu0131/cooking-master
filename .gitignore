# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# project data
/data
*.log
.idea/
.vscode/

# prisma
/prisma/migrations/dev.db*

# capacitor / android (mobile 壳)
# android/ 完全由 capacitor.config.ts 生成、无手改，整目录不入库（见 mobile/README.md 重建步骤）
/mobile/node_modules
/mobile/android
/mobile/*.keystore
/mobile/*.apk
