# ========================================
# 厨神 · 环境变量模板
# 复制此文件为 .env 并填写真实值
# ========================================

# 数据库
DATABASE_URL="postgresql://cooking:CHANGEME@localhost:5432/cooking_master?schema=public"

# Auth.js
AUTH_SECRET="CHANGEME_USE_openssl_rand_base64_32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# DeepSeek AI
DEEPSEEK_API_KEY="sk-CHANGEME"
DEEPSEEK_API_BASE="https://api.deepseek.com/v1"
# 用 deepseek-chat（非 reasoning）；v4-pro 跑结构化任务会满 180s 超时，见 NOTES 坑9
DEEPSEEK_MODEL="deepseek-chat"

# 图片存储路径（容器内）
IMAGES_DIR="/app/data/images"

# ── 功能开关（默认关闭 = 安全优先；公网部署务必保持关闭）──
# 允许自助创建新家庭（不带邀请码注册）。公网保持 0，加家人用邀请码；仅本地初始化首个家庭时设 1。
ALLOW_OPEN_REGISTRATION="0"
# 启用菜品「换图」实时网络抓图。有 NSFW/SSRF 风险（命中率低），默认 0；日常用「上传照片」即可。
ENABLE_DISH_IMAGE_FETCH="0"

# 应用基础 URL（用于绝对路径生成）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
