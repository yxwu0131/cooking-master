# ========================================
# 厨神 · 生产环境变量（部署到极空间用）
# 复制为 .env 放在 docker-compose.yml 同目录
# ========================================

# === 域名与对外暴露 ===
# 子域名：cook.dorianweb.com
# 【LAN + Cloudflare Tunnel（推荐）】用内网地址，TLS 由 Cloudflare 托管：
#   AUTH_URL / NEXT_PUBLIC_APP_URL 见下方，填 https://cook.dorianweb.com
# 【public profile（Caddy 自签证书，需公网 IP）才需要】：
DOMAIN=cook.dorianweb.com
LETSENCRYPT_EMAIL=your-email@example.com

# === Cloudflare Tunnel（仅 docker-compose.cloudflared.yml 新建独立隧道时需要）===
# 复用现有隧道则不用填，在 Cloudflare 后台加 public hostname 路由即可
CF_TUNNEL_TOKEN=

# === 数据库（容器内访问） ===
POSTGRES_USER=cooking
POSTGRES_PASSWORD=  # 随机生成 32+ 位强密码：openssl rand -base64 24
POSTGRES_DB=cooking_master

# === Auth.js ===
AUTH_SECRET=  # 必须 32+ 位：openssl rand -base64 32
AUTH_URL=https://cook.dorianweb.com
NEXT_PUBLIC_APP_URL=https://cook.dorianweb.com

# === DeepSeek V4 Pro ===
DEEPSEEK_API_KEY=sk-
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# ⚠️ 不要用 deepseek-v4-pro（reasoning model，菜单推荐这种结构化任务太慢，180s+ 容易超时）
# deepseek-chat 已知 2026-06 下线，到时切到 flash 类
